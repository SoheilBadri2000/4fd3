# MongoDB connection string.
# Local dev:  mongodb://localhost:27017/medical-assistant
# Docker:     set automatically by docker-compose — no change needed here.
MONGODB_URI=mongodb://localhost:27017/medical-assistant

# A long random string used to sign JWT tokens.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Free API key from https://console.groq.com 
GROQ_API_KEY=gsk_your_key_here

# Port the Node.js server listens on.
PORT=3001

# URL of the frontend — used for CORS.
# Local dev:  http://localhost:3000
FRONTEND_URL=http://localhost:3000
