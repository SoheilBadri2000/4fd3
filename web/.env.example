# ── web/.env.local ────────────────────────────────────────────────────────────
# Copy this file:  cp web/.env.example web/.env.local
# Only needed for local dev without Docker.
# When running with Docker, docker-compose sets API_URL automatically.
# ──────────────────────────────────────────────────────────────────────────────

# URL of the Node.js API server.
# Local dev:  http://localhost:3001
# Docker:     http://server:3001  (set by docker-compose — no change needed)
API_URL=http://localhost:3001
